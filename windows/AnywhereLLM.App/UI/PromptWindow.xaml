<Window x:Class="AnywhereLLM.UI.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" ShowActivated="True"
        WindowStartupLocation="Manual" PreviewKeyDown="Window_PreviewKeyDown">
  <Border CornerRadius="10" Width="460" BorderThickness="1"
          Background="{DynamicResource Brush.Surface}"
          BorderBrush="{DynamicResource Brush.Border}"
          TextElement.Foreground="{DynamicResource Brush.Text}">
    <Border.Effect>
      <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.35"/>
    </Border.Effect>
    <StackPanel Margin="12">
      <DockPanel x:Name="ProfileRow" LastChildFill="False" Margin="0,0,0,8">
        <ComboBox x:Name="ProfileBox" DockPanel.Dock="Left" MinWidth="120"
                  SelectionChanged="ProfileBox_SelectionChanged"
                  DropDownClosed="ProfileBox_DropDownClosed"/>
        <TextBlock DockPanel.Dock="Left" Text="Ctrl+P" Margin="6,0,0,0"
                   VerticalAlignment="Center" Opacity="0.5" FontSize="11"/>
      </DockPanel>

      <Image x:Name="ThumbImage" MaxHeight="160" Margin="0,0,0,8" Stretch="Uniform"
             HorizontalAlignment="Left" Visibility="Collapsed"/>

      <TextBlock x:Name="SelectionPreview" TextWrapping="Wrap" MaxHeight="42" Margin="0,0,0,8"
                 Opacity="0.7" TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>

      <Border x:Name="ResultBox" CornerRadius="6" Padding="8" Margin="0,0,0,8" Visibility="Collapsed"
              Background="{DynamicResource Brush.SurfaceAlt}">
        <ScrollViewer x:Name="ResultScroll" MaxHeight="280" VerticalScrollBarVisibility="Auto">
          <TextBox x:Name="ResultText" IsReadOnly="True" BorderThickness="0"
                   Background="Transparent" Foreground="{DynamicResource Brush.Text}" TextWrapping="Wrap"/>
        </ScrollViewer>
      </Border>

      <TextBlock x:Name="ErrorText" Foreground="#D14343" TextWrapping="Wrap"
                 Margin="0,0,0,8" Visibility="Collapsed"/>

      <Grid>
        <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="32"
                 MaxHeight="130" Padding="6" VerticalScrollBarVisibility="Auto"
                 TextChanged="InputBox_TextChanged" PreviewKeyDown="InputBox_PreviewKeyDown"/>
        <TextBlock x:Name="InputHint" IsHitTestVisible="False" Opacity="0.5"
                   Margin="9,8,0,0" VerticalAlignment="Top"/>
      </Grid>

      <StackPanel x:Name="LoadingRow" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
        <TextBlock x:Name="LoadingText" Opacity="0.7"/>
      </StackPanel>

      <Button x:Name="ApplyButton" Margin="0,8,0,0" Padding="0,4"
              Click="ApplyButton_Click" Visibility="Collapsed"/>
    </StackPanel>
  </Border>
</Window>
